# W4GZ — environment variables (copy to .env.local; all are OPTIONAL in dev).
# The on-site forms (Update 8) degrade gracefully: with nothing set, submissions
# are accepted + logged (not persisted/emailed) and the spam challenge is skipped,
# so /dang-ky and /nop-bai-tot-nghiep work locally. Set these for production.

# ── Persistence: your own Postgres via Supabase/PostgREST (owned instance, RLS) ──
# Create the table from docs/forms-schema.sql first.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# Optional: override the table name (default: form_submissions)
SUBMISSIONS_TABLE=
# Optional app-layer encryption for free-text (base64 of 32 random bytes):
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
FORMS_ENCRYPTION_KEY=

# ── Spam: Cloudflare Turnstile (privacy-friendly; not reCAPTCHA) ──
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# ── Email: Resend on your own sending domain ──
RESEND_API_KEY=
FORMS_FROM_EMAIL=
FORMS_TEAM_EMAIL=

# ── Misc ──
# Salt for hashing IPs (rate-limit/dedupe without storing raw IPs)
FORMS_IP_SALT=
# Bearer token for the team-only export route (/api/admin/export). Unset = locked.
ADMIN_EXPORT_TOKEN=
